# API
PORT=8000
NODE_ENV=development
CORS_ORIGIN="http://localhost:3000"
PUBLIC_APP_URL="http://localhost:3000"

# PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/flowforce_hrm?schema=public"

# JWT (to be used when auth module is added)
JWT_ACCESS_SECRET="replace-me"
JWT_REFRESH_SECRET="replace-me"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Cloudinary (image storage)
CLOUDINARY_CLOUD_NAME="replace-me"
CLOUDINARY_API_KEY="replace-me"
CLOUDINARY_API_SECRET="replace-me"

# Razorpay (replace with your actual keys)
RAZORPAY_KEY_ID="rzp_test_dummy_replace_me"
RAZORPAY_KEY_SECRET="rzp_test_dummy_secret_replace_me"
RAZORPAY_WEBHOOK_SECRET="razorpay_webhook_dummy_replace_me"

# In-house Queue Worker
QUEUE_POLL_INTERVAL_MS=5000
QUEUE_BATCH_SIZE=10

# Payroll
PAYROLL_BASE_HOURLY_RATE=100
PAYROLL_OT_MULTIPLIER=1.5

# Mailbox OAuth (server-side secure credentials)
MAIL_TOKEN_ENCRYPTION_KEY="replace-with-a-long-random-secret"
MAIL_GOOGLE_CLIENT_ID="replace-me"
MAIL_GOOGLE_CLIENT_SECRET="replace-me"
MAIL_GOOGLE_REDIRECT_URI="http://localhost:3000/mailbox"
MAIL_MICROSOFT_CLIENT_ID="replace-me"
MAIL_MICROSOFT_CLIENT_SECRET="replace-me"
MAIL_MICROSOFT_REDIRECT_URI="http://localhost:3000/mailbox"
